{
  "extends": ["stylelint-config-standard"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "import",
          "source",
          "custom-variant",
          "theme",
          "apply",
          "layer",
          "tailwind"
        ]
      }
    ]
  }
}
